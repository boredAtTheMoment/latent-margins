---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const resume = await getEntry("resume", "main");

if (!resume) {
  throw new Error("Missing resume content at src/content/resume/main.md");
}

const { Content } = await render(resume);

const linkClass = (label: string) =>
  `resume-link resume-link-${label.toLowerCase().replace(/\s+/g, "-")}`;
---

<BaseLayout title={`${resume.data.title} | Resume`} description={resume.data.description}>
  <main>
    <article class="resume-page">
      <header>
        <p class="eyebrow">Resume</p>
        <h1>{resume.data.title}</h1>
        <p class="lede">{resume.data.description}</p>
        <div class="resume-links" aria-label="Professional links">
          {
            resume.data.links.map((link) => (
              <a class={linkClass(link.label)} href={link.href} rel="noreferrer">
                {link.label === "GitHub" ? (
                  <svg aria-hidden="true" viewBox="0 0 24 24">
                    <path d="M12 2.2a10 10 0 0 0-3.16 19.49c.5.09.68-.22.68-.48v-1.7c-2.77.6-3.35-1.18-3.35-1.18-.45-1.14-1.1-1.45-1.1-1.45-.9-.61.07-.6.07-.6 1 .07 1.53 1.03 1.53 1.03.88 1.51 2.31 1.07 2.87.82.09-.64.35-1.07.63-1.32-2.21-.25-4.53-1.1-4.53-4.92 0-1.09.39-1.98 1.03-2.68-.1-.25-.45-1.27.1-2.64 0 0 .84-.27 2.75 1.02a9.45 9.45 0 0 1 5 0c1.91-1.29 2.75-1.02 2.75-1.02.55 1.37.2 2.39.1 2.64.64.7 1.03 1.59 1.03 2.68 0 3.83-2.33 4.66-4.55 4.91.36.31.68.92.68 1.86v2.75c0 .27.18.58.69.48A10 10 0 0 0 12 2.2Z" />
                  </svg>
                ) : link.label === "LinkedIn" ? (
                  <svg aria-hidden="true" viewBox="0 0 24 24">
                    <path d="M5.1 8.8h3.6v11.6H5.1V8.8Zm1.8-5.7a2.1 2.1 0 1 1 0 4.2 2.1 2.1 0 0 1 0-4.2Zm4.1 5.7h3.45v1.58h.05c.48-.91 1.66-1.87 3.42-1.87 3.66 0 4.34 2.41 4.34 5.55v6.34h-3.6v-5.63c0-1.34-.02-3.07-1.87-3.07-1.88 0-2.17 1.47-2.17 2.98v5.72H11V8.8Z" />
                  </svg>
                ) : (
                  <svg aria-hidden="true" viewBox="0 0 24 24">
                    <path d="M12 3.2 2.9 8.4 12 13.6l9.1-5.2L12 3.2Zm-5.6 8.2v4.3c0 2 2.5 3.6 5.6 3.6s5.6-1.6 5.6-3.6v-4.3L12 14.6l-5.6-3.2Zm12.3.1v4.1h1.6v-5l-1.6.9Z" />
                  </svg>
                )}
                {link.label}
              </a>
            ))
          }
        </div>
      </header>
      <Content />
    </article>
  </main>
</BaseLayout>
